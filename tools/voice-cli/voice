#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "${SOURCE}" ]; do
  SCRIPT_DIR="$(cd -- "$(dirname -- "${SOURCE}")" && pwd)"
  TARGET="$(readlink -- "${SOURCE}")"
  if [[ "${TARGET}" == /* ]]; then
    SOURCE="${TARGET}"
  else
    SOURCE="${SCRIPT_DIR}/${TARGET}"
  fi
done
SCRIPT_DIR="$(cd -- "$(dirname -- "${SOURCE}")" && pwd)"

DOCTOR_ARGS=()
SOCKET_ARGS=()
SHORTCUT_ARGS=()
DAEMON_SHORTCUT_ARGS=()
PIPELINE_ARGS=(
  --refine "${VOICE_REFINE:-heuristic}"
  --whisper-timeout "${VOICE_WHISPER_TIMEOUT:-120}"
)
if [[ -n "${VOICE_WHISPER_CLI:-}" ]]; then
  DOCTOR_ARGS+=(--whisper-cli "${VOICE_WHISPER_CLI}")
  PIPELINE_ARGS+=(--whisper-cli "${VOICE_WHISPER_CLI}")
fi
if [[ -n "${VOICE_LLAMA_CLI:-}" ]]; then
  DOCTOR_ARGS+=(--llama-cli "${VOICE_LLAMA_CLI}")
  PIPELINE_ARGS+=(--llama-cli "${VOICE_LLAMA_CLI}")
fi
if [[ -n "${VOICE_WHISPER_MODEL:-}" ]]; then
  DOCTOR_ARGS+=(--whisper-model "${VOICE_WHISPER_MODEL}")
  PIPELINE_ARGS+=(--whisper-model "${VOICE_WHISPER_MODEL}")
fi
if [[ -n "${VOICE_LLAMA_MODEL:-}" ]]; then
  DOCTOR_ARGS+=(--llama-model "${VOICE_LLAMA_MODEL}")
  PIPELINE_ARGS+=(--llama-model "${VOICE_LLAMA_MODEL}")
fi
if [[ -n "${VOICE_LANGUAGE:-}" ]]; then
  PIPELINE_ARGS+=(--language "${VOICE_LANGUAGE}")
fi
if [[ -n "${VOICE_WHISPER_THREADS:-}" ]]; then
  PIPELINE_ARGS+=(--whisper-threads "${VOICE_WHISPER_THREADS}")
fi
if [[ -n "${VOICE_WHISPER_BEAM_SIZE:-}" ]]; then
  PIPELINE_ARGS+=(--whisper-beam-size "${VOICE_WHISPER_BEAM_SIZE}")
fi
if [[ -n "${VOICE_WHISPER_BEST_OF:-}" ]]; then
  PIPELINE_ARGS+=(--whisper-best-of "${VOICE_WHISPER_BEST_OF}")
fi
if [[ "${VOICE_WHISPER_FALLBACK:-0}" =~ ^(1|true|True|yes|Yes)$ ]]; then
  PIPELINE_ARGS+=(--whisper-fallback)
fi
if [[ -n "${VOICE_WHISPER_MAX_CONTEXT:-}" ]]; then
  PIPELINE_ARGS+=(--whisper-max-context "${VOICE_WHISPER_MAX_CONTEXT}")
fi
if [[ "${VOICE_TRIM_SILENCE:-1}" =~ ^(0|false|False|no|No)$ ]]; then
  PIPELINE_ARGS+=(--no-trim-silence)
fi
if [[ -n "${VOICE_TRIM_SILENCE_MS:-}" ]]; then
  PIPELINE_ARGS+=(--trim-silence-ms "${VOICE_TRIM_SILENCE_MS}")
fi
if [[ -n "${VOICE_TRIM_SILENCE_THRESHOLD:-}" ]]; then
  PIPELINE_ARGS+=(--trim-silence-threshold "${VOICE_TRIM_SILENCE_THRESHOLD}")
fi
if [[ -n "${VOICE_MIN_SPEECH_SECONDS:-}" ]]; then
  PIPELINE_ARGS+=(--min-speech-seconds "${VOICE_MIN_SPEECH_SECONDS}")
fi
if [[ "${VOICE_AUTO_PASTE:-}" =~ ^(1|true|True|yes|Yes)$ ]]; then
  PIPELINE_ARGS+=(--auto-paste)
elif [[ "${VOICE_AUTO_PASTE:-}" =~ ^(0|false|False|no|No)$ ]]; then
  PIPELINE_ARGS+=(--no-auto-paste)
fi
if [[ -n "${VOICE_PASTE_DELAY_MS:-}" ]]; then
  PIPELINE_ARGS+=(--paste-delay-ms "${VOICE_PASTE_DELAY_MS}")
fi
if [[ -n "${VOICE_PASTE_TOOL:-}" ]]; then
  PIPELINE_ARGS+=(--paste-tool "${VOICE_PASTE_TOOL}")
fi
if [[ -n "${VOICE_HOTKEY:-}" ]]; then
  SHORTCUT_ARGS+=(--hotkey "${VOICE_HOTKEY}")
  DAEMON_SHORTCUT_ARGS+=(--hotkey "${VOICE_HOTKEY}")
fi
if [[ -n "${VOICE_SOCKET_PATH:-}" ]]; then
  SOCKET_ARGS+=(--socket-path "${VOICE_SOCKET_PATH}")
fi
if [[ -n "${VOICE_SHORTCUT_BACKEND:-}" ]]; then
  DAEMON_SHORTCUT_ARGS+=(--shortcut-backend "${VOICE_SHORTCUT_BACKEND}")
fi

COMMAND="${1:-tui}"
case "${COMMAND}" in
  doctor|record|transcribe|refine|model-install|run|tui|hotkey|daemon|trigger|service|shortcut-status)
    shift || true
    ;;
  *)
    COMMAND="tui"
    ;;
esac

COMMAND_ARGS=()
if [[ "${COMMAND}" == "tui" ]]; then
  COMMAND_ARGS+=(--seconds "${VOICE_SECONDS:-5}")
fi

DEFAULT_ARGS=()
case "${COMMAND}" in
  doctor)
    DEFAULT_ARGS=("${DOCTOR_ARGS[@]}")
    ;;
  run)
    DEFAULT_ARGS=("${PIPELINE_ARGS[@]}")
    ;;
  tui|hotkey)
    DEFAULT_ARGS=("${PIPELINE_ARGS[@]}" "${SHORTCUT_ARGS[@]}")
    ;;
  daemon)
    DEFAULT_ARGS=("${PIPELINE_ARGS[@]}" "${SOCKET_ARGS[@]}" "${DAEMON_SHORTCUT_ARGS[@]}")
    ;;
  trigger)
    DEFAULT_ARGS=("${SOCKET_ARGS[@]}")
    ;;
esac

exec python3 -B "${SCRIPT_DIR}/voice.py" "${COMMAND}" \
  "${COMMAND_ARGS[@]}" \
  "${DEFAULT_ARGS[@]}" \
  "$@"
